# Supabase
SUPABASE_URL=your_project_url
SUPABASE_KEY=your_service_role_key

# Telegram
BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Scraper settings
SEARCH_TERM=محاسب
MAX_PAGES=3
LOCATION_FILTER=Cairo,Giza,Monufia
MAX_EXPERIENCE_YEARS=5
EXPIRE_DAYS=14
NOTIFY_ON_SUCCESS=true

# Bot settings
NOTIFY_INTERVAL_SECONDS=21600  # 6 ساعات

# Applicant info (للرسالة الجاهزة)
APPLICANT_NAME=اسمك
APPLICANT_PHONE=0123456789
APPLICANT_EMAIL=your@email.com
APPLICANT_SUMMARY=محاسب بخبرة في القيد المزدوج والتسويات البنكية
