# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Telegram
BOT_TOKEN=your_bot_token
ALLOWED_USER_IDS=your_telegram_id

# Auto Apply
AUTO_APPLY_ENABLED=true
WHATSAPP_NUMBER=2010xxxxxxxx

# Applicant Info
APPLICANT_NAME=Your Name
APPLICANT_PHONE=2010xxxxxxxx
APPLICANT_EMAIL=your@email.com
APPLICANT_SUMMARY=Your professional summary

# Scraper
SEARCH_TERM=محاسب
MAX_PAGES=3
LOCATION_FILTER=Cairo,Giza,Menoufia
MAX_EXPERIENCE_YEARS=5
EXPIRE_DAYS=14
NOTIFY_ON_SUCCESS=true
NOTIFY_INTERVAL_SECONDS=21600
