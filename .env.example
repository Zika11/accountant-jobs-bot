# ========================
# Supabase (قاعدة البيانات)
# ========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ========================
# Telegram Bot
# ========================
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ========================
# اعدادات البوت الشخصي (أنت بس)
# ========================
ALLOWED_USER_IDS=123456789

# ========================
# اعدادات التقديم التلقائي (Auto Apply)
# ========================
AUTO_APPLY_ENABLED=true
WHATSAPP_NUMBER=2010xxxxxxxx

# ========================
# بياناتك الشخصية للرسالة الجاهزة
# ========================
APPLICANT_NAME=Your Full Name
APPLICANT_PHONE=2010xxxxxxxx
APPLICANT_EMAIL=your@email.com
APPLICANT_SUMMARY=Your professional summary here...

# ========================
# إعدادات السكرابر (جمع الوظائف)
# ========================
# البحث عن "محاسب" و "محاسب حديث التخرج"
SEARCH_TERM=محاسب حديث التخرج
MAX_PAGES=3
LOCATION_FILTER=Cairo,Giza,Menoufia
# فلترة الخبرة (0-3 سنوات)
MAX_EXPERIENCE_YEARS=3
EXPIRE_DAYS=14
NOTIFY_ON_SUCCESS=true

# ========================
# إعدادات البوت
# ========================
NOTIFY_INTERVAL_SECONDS=21600

# ========================
# تليجرام (لجلب الوظائف من القنوات)
# ========================
TELEGRAM_BOT_TOKEN_FOR_SCRAPING=your_telegram_bot_token_here
TELEGRAM_CHANNELS=WazaefMasr,Shaghalni,AccountingJobsEgypt

# ========================
# فيسبوك (لجلب الوظائف من الجروبات)
# ========================
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_GROUPS=123456789,987654321
